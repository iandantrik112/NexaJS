{
  "name": "nexareact",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "check:nexajs-imports": "node ./assets/modules/NexaReact/NexaJSImports.mjs",
    "precommit": "npm run check:nexajs-imports",
    "prestart": "npm run check:nexajs-imports",
    "preandroid": "npm run check:nexajs-imports",
    "preios": "npm run check:nexajs-imports",
    "preweb": "npm run check:nexajs-imports",
    "start": "expo start --port 9005",
    "start:clear": "expo start --port 9005 --clear",
    "start:show": "node show-expo-url.js && expo start --port 9005",
    "start:tunnel": "expo start --tunnel --port 9005",
    "start:lan": "expo start --lan --port 9005",
    "show-url": "node show-expo-url.js",
    "android": "expo run:android",
    "android:build": "cd android && gradlew.bat assembleRelease",
    "android:build:bundle": "cd android && gradlew.bat bundleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web --host --port 9005",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "base-64": "^1.0.0",
    "canvas": "^3.1.0",
    "cross-env": "^7.0.3",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.4.4",
    "expo": "~54.0.6",
    "expo-camera": "~17.0.9",
    "expo-dev-client": "^6.0.17",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.9",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-location": "~19.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-speech": "~14.0.7",
    "expo-sqlite": "~16.0.9",
    "expo-status-bar": "~3.0.8",
    "expo-video": "~2.0.0",
    "lodash": "^4.17.21",
    "NexaJS": "file:./assets/modules",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dropdown-select-list": "^2.0.5",
    "react-native-elements": "^3.4.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-picker": "^8.2.0",
    "react-native-paper": "^5.11.4",
    "react-native-pell-rich-editor": "^1.9.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-redux": "^9.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-community/cli": "^12.3.5",
    "babel-preset-expo": "~54.0.0",
    "expo-build-properties": "^1.0.10",
    "husky": "^9.1.7"
  },
  "private": true
}
